{
  "name": "chronicle",
  "private": true,
  "version": "1.0.11",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"cross-env NODE_ENV=development vite\" \"cross-env NODE_ENV=development electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && electron-builder --publish never",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.chronicle.app",
    "productName": "Chronicle",
    "copyright": "MIT",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "relay/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "relay",
        "to": "relay",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "MattsTryingAgain",
      "repo": "chronicle"
    },
    "directories": {
      "output": "release",
      "buildResources": "assets"
    }
  },
  "dependencies": {
    "@noble/secp256k1": "^3.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@types/d3": "^7.4.3",
    "@types/sql.js": "^1.4.11",
    "@vitest/ui": "^4.1.2",
    "bootstrap": "^5.3.8",
    "d3": "^7.9.0",
    "i18next": "^26.0.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "nostr-tools": "^2.23.3",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.1",
    "secrets.js-34r7h": "^2.0.2",
    "sql.js": "^1.14.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "vitest": "^4.1.2",
    "ws": "^8.20.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "electron": "^34.0.0"
  },
  "description": "Decentralised family history \u2014 privacy-first, cryptographically verifiable",
  "author": {
    "name": "MattsTryingAgain",
    "email": "chronicle@example.com"
  }
}
